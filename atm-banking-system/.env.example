# ─── Application ────────────────────────────────────────────────────────────
APP_NAME="ATM Banking System"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256

# ─── Session / Token ────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1          # 90 seconds → use 1.5 or set seconds below
SESSION_INACTIVITY_SECONDS=90

# ─── Database ───────────────────────────────────────────────────────────────
# Production (PostgreSQL)
DATABASE_URL=postgresql://atm_user:atm_pass@localhost:5432/atm_banking

# Development / Testing (SQLite)
# DATABASE_URL=sqlite:///./atm_banking.db

# ─── Security ───────────────────────────────────────────────────────────────
PIN_HASH_ALGORITHM=argon2              # argon2 | bcrypt
MAX_PIN_ATTEMPTS=3
CARD_NUMBER_ENCRYPTION_KEY=change-me-32-byte-fernet-key-here==

# ─── ATM Defaults ───────────────────────────────────────────────────────────
DEFAULT_DENOMINATION=20                # smallest note the ATM dispenses
LOW_CASH_THRESHOLD=5000                # alert when cassette drops below this
DEFAULT_DAILY_WITHDRAWAL_LIMIT=1000
DEFAULT_DAILY_TRANSFER_LIMIT=5000
MAX_SINGLE_WITHDRAWAL=500
MAX_SINGLE_DEPOSIT=10000
DEPOSIT_HOLD_DAYS=1

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=change-me-admin-secret-key

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                        # json | console
